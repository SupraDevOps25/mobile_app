{
  "name": "supramobile",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "api"
  ],
  "scripts": {
    "dev": "concurrently --names \"api,mobile\" -c \"blue,green\" \"npm run dev:api\" \"npm run dev:mobile\"",
    "dev:api": "turbo dev --filter=@supramobile/api",
    "dev:mobile": "npm --prefix mobile run start",
    "build:api": "turbo build --filter=@supramobile/api",
    "install:all": "npm install --prefix api && npm install --prefix mobile"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.5.4"
  }
}
