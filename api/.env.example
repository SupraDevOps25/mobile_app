# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Public base URL of THIS API (used in emails/links). In dev this is your LAN
# URL or an ngrok tunnel, e.g. http://192.168.0.114:3000
API_URL="http://localhost:3000"

# ─── Database (Neon Postgres) ───────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"

# ─── Auth ───────────────────────────────────────────────────────────────────
# Long random string. Generate one: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret"

# ─── Paystack (payments) ────────────────────────────────────────────────────
# Get keys from https://dashboard.paystack.com/#/settings/developers
# DEV: use the TEST secret key (starts with sk_test_...).
# PROD: swap in the LIVE secret key (starts with sk_live_...). Never commit it.
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Optional. Where Paystack redirects after the hosted checkout. The app also
# verifies server-side on return, so this is mostly cosmetic in dev.
PAYSTACK_CALLBACK_URL=""
# Optional. Defaults to PAYSTACK_SECRET_KEY (Paystack signs webhooks with it).
# Only set this if you configure a separate webhook signing secret.
PAYSTACK_WEBHOOK_SECRET=""

# ─── Email (SMTP, optional in dev) ──────────────────────────────────────────
# If unset, invoice emails are logged to the console instead of sent.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Supracarer <no-reply@supracarer.com>"

# ─── WhatsApp / SMS (Twilio, optional) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""
