generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  FAMILY
  CAREGIVER // the nurse
  CARE_COORDINATOR
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

// Whether a family is booking care for themselves or for a loved one.
enum BookingFor {
  SELF
  LOVED_ONE
}

enum VerificationStatus {
  UNVERIFIED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

// Caregiver-uploaded credentials. MVP collects two cards: the Ghana Card
// (national ID) and the Nursing & Midwifery Council PIN card (licence).
enum CaregiverDocumentType {
  GHANA_CARD
  PIN_CARD
}

// Per-document review state (an admin verifies manually).
enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

// Clinical competencies used for nurse matching. Mirrors the mobile
// CompetencyId catalog (constants/competencies.ts).
enum Competency {
  PERSONAL_CARE
  HYGIENE
  FEEDING
  MOBILITY
  MEDICATION
  VITALS
  WOUND_CARE
  CATHETER_CARE
  CHRONIC_DISEASE
  HYPERTENSION
  DIABETES
  STROKE_REHAB
  DEMENTIA
  GERIATRIC
  REHAB
  PALLIATIVE
}

enum PackageType {
  WELLNESS
  DAILY_ASSIST
  EXTENDED_ASSIST
  LIVE_IN
}

// Care journey states. AWAITING_ACTIVATION is the coordinator-controlled gate:
// after the initial assessment and the nurse starting, the Care Coordinator
// activates the care (it does not auto-start). See care-journey-workflow.
enum SubscriptionStatus {
  MATCHING // subscribed; system + coordinator assembling the care team
  TEAM_ASSIGNED // team set; initial home visit pending
  AWAITING_ACTIVATION // assessment done; awaiting coordinator activation
  ACTIVE // care delivery underway
  RENEWING // month-end review & renewal
  PAUSED
  CANCELLED
}

enum AssignmentRole {
  PRIMARY
  BACKUP_1
  BACKUP_2
  ASSISTANT // second nurse sharing a full-time case (rotates days with the lead)
}

enum AssignmentStatus {
  OFFERED
  ACCEPTED
  DECLINED
  ACTIVE
  REPLACED
}

enum VisitKind {
  INITIAL_ASSESSMENT // joint coordinator + nurse home visit
  CARE_VISIT
}

enum VisitStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  MISSED
}

enum PatientMood {
  POOR
  LOW
  GOOD
  GREAT
  EXCELLENT
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  ABANDONED
}

// Nurse payout requests (withdraw realized earnings to mobile money).
enum PayoutStatus {
  PENDING // requested, awaiting disbursement
  PAID // disbursed to the nurse
}

enum NotificationType {
  SUBSCRIPTION_CREATED
  TEAM_ASSIGNED
  ASSIGNMENT_OFFER
  ASSIGNMENT_ACCEPTED
  ASSIGNMENT_DECLINED
  CARE_ACTIVATED
  VISIT_REMINDER
  DAILY_LOG_SUBMITTED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  GENERAL
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  phone         String   @unique
  password      String
  firstName     String
  lastName      String
  role          Role
  emailVerified Boolean  @default(false)
  // Outbound notification channels (the in-app inbox is always on).
  notifyPush    Boolean  @default(true)
  notifySms     Boolean  @default(true)
  // Expo push token for this user's current device (any role).
  fcmToken      String?
  // Self-uploaded profile photo (used by roles without a profile table, e.g.
  // Care Coordinators; families/nurses keep their own on their profile row).
  photoUrl      String?
  photoPublicId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  caregiverProfile   CaregiverProfile?
  familyProfile      FamilyProfile?
  coordinatorProfile CoordinatorProfile?
  notifications      Notification[]
  emailVerifications EmailVerification[]
  messages           Message[]

  // Coordinator-side relations (role = CARE_COORDINATOR)
  coordinatedSubscriptions Subscription[] @relation("CoordinatorSubscriptions")
  reviewedLogs             VisitLog[]     @relation("LogReviewer")

  @@map("users")
}

model EmailVerification {
  id        String   @id @default(uuid())
  token     String   @unique @default(uuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// ─── Nurse (Caregiver) Profile ────────────────────────────────────────────────

model CaregiverProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  qualification      String?
  bio                String?
  gender             Gender?
  dateOfBirth        DateTime? // used to show the nurse's age
  address            String? // the nurse's home address
  yearsExperience    Int                @default(0)
  hasHomecareExp     Boolean            @default(false) // worked as a homecare nurse before?
  languages          String[]           @default([]) // e.g. English, Twi, Ga
  photoUrl           String? // Cloudinary secure URL
  photoPublicId      String? // Cloudinary public id (for replace/delete)
  competencies       Competency[]
  serviceAreas       String[]
  licenseVerified    Boolean            @default(false)
  isAvailable        Boolean            @default(true) // nurse-controlled (availability screen)
  // Weekly working pattern (schedule screen). workingDays uses JS getDay():
  // 0=Sun … 6=Sat. Hours are "HH:MM" 24h strings.
  workingDays        Int[]              @default([1, 2, 3, 4, 5])
  workStart          String             @default("08:00")
  workEnd            String             @default("17:00")
  maxVisitsPerDay    Int                @default(3)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  rating             Decimal            @default(0) @db.Decimal(3, 2)
  reliabilityScore   Int                @default(0) // 0–100
  totalReviews       Int                @default(0)
  lat                Float?
  lng                Float?
  fcmToken           String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments    Assignment[]
  visits         Visit[]
  documents      CaregiverDocument[]
  reviews        Review[]
  payoutRequests PayoutRequest[]

  @@map("caregiver_profiles")
}

// A single uploaded credential (one current record per type per caregiver).
// The file itself lives in Cloudinary; we store only its URL + metadata.
model CaregiverDocument {
  id           String                @id @default(uuid())
  caregiverId  String
  type         CaregiverDocumentType
  idNumber     String? // the number printed on the card (Ghana Card PIN, NMC PIN)
  url          String // Cloudinary secure URL
  publicId     String // Cloudinary public id
  fileName     String?
  status       DocumentStatus        @default(PENDING)
  reviewNote   String? // admin's reason on reject
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  caregiver CaregiverProfile @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  @@unique([caregiverId, type])
  @@map("caregiver_documents")
}

// ─── Family Profile ───────────────────────────────────────────────────────────

model FamilyProfile {
  id            String    @id @default(uuid())
  userId        String    @unique
  address       String?
  lat           Float?
  lng           Float?
  gender        Gender?
  dateOfBirth   DateTime? // shows the account holder's age (e.g. when booking for self)
  photoUrl      String? // Cloudinary secure URL
  photoPublicId String? // Cloudinary public id (for replace/delete)
  fcmToken      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  careRecipients CareRecipient[]
  subscriptions  Subscription[]
  payments       Payment[]
  savedAddresses SavedAddress[]
  paymentMethods PaymentMethod[]
  reviews        Review[]

  @@map("family_profiles")
}

// Care Coordinator profile. Coordinators log in as plain Users; this holds
// their personal + professional details (the account photo lives on User).
model CoordinatorProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  gender          Gender?
  dateOfBirth     DateTime? // shows the coordinator's age
  address         String? // home / house address
  lat             Float?
  lng             Float?
  yearsExperience Int       @default(0) // years in care coordination / nursing
  bio             String? // "about me" blurb
  workplace       String? // where they work (hospital / organisation)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coordinator_profiles")
}

// A reusable Paystack authorization captured after a successful payment. We
// never store raw card details — only Paystack's token plus safe metadata.
// The authorizationCode is server-only and is never returned to the client.
model PaymentMethod {
  id                String   @id @default(uuid())
  familyId          String
  authorizationCode String   @unique
  channel           String // "card" | "mobile_money" | "bank"
  brand             String? // visa / mastercard / MTN, etc.
  last4             String?
  bank              String?
  expMonth          String?
  expYear           String?
  reusable          Boolean  @default(true)
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  family FamilyProfile @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("payment_methods")
}

model SavedAddress {
  id        String   @id @default(uuid())
  familyId  String
  label     String // "Home", "Work", "Other", or a custom label
  address   String // full address line
  area      String? // neighbourhood / area
  city      String?
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family FamilyProfile @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("saved_addresses")
}

// ─── Care Recipient (the client receiving care) ───────────────────────────────

model CareRecipient {
  id                String     @id @default(uuid())
  familyId          String
  bookingFor        BookingFor @default(LOVED_ONE) // self vs. loved one
  name              String
  age               Int
  gender            Gender
  relationToAccount String // "Self" when bookingFor = SELF; else e.g. "Father"
  area              String
  city              String
  address           String
  conditions        String[]
  basicCareNeeds    String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  family        FamilyProfile  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@map("care_recipients")
}

// ─── Package catalog ──────────────────────────────────────────────────────────

model Package {
  id         String      @id @default(uuid())
  type       PackageType @unique
  name       String
  tagline    String
  priceGhs   Decimal     @db.Decimal(10, 2)
  inclusions String[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("packages")
}

// ─── Subscription (the "case" container) ──────────────────────────────────────

model Subscription {
  id              String             @id @default(uuid())
  familyId        String
  careRecipientId String
  packageType     PackageType
  priceGhs        Decimal            @db.Decimal(10, 2) // snapshot at subscribe time
  status          SubscriptionStatus @default(MATCHING)
  coordinatorId   String? // User with role CARE_COORDINATOR
  needsAssistant  Boolean            @default(false) // full-time case: lead nurse wants a second nurse
  assessmentAt    DateTime? // agreed initial home-visit (assessment) date/time
  careStartAt     DateTime? // day/time care begins, agreed with the family at assessment
  activatedAt     DateTime? // when the coordinator activated care
  startedAt       DateTime           @default(now())
  renewsAt        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  family        FamilyProfile @relation(fields: [familyId], references: [id])
  careRecipient CareRecipient @relation(fields: [careRecipientId], references: [id])
  coordinator   User?         @relation("CoordinatorSubscriptions", fields: [coordinatorId], references: [id])
  assignments   Assignment[]
  visits        Visit[]
  payments      Payment[]
  reviews       Review[]
  messages      Message[]

  @@map("subscriptions")
}

// ─── Message (family ⇄ care coordinator chat, scoped to a subscription) ────────
model Message {
  id             String    @id @default(uuid())
  subscriptionId String
  senderId       String // User id (the family account holder or the coordinator)
  body           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("messages")
}

// ─── Review (family rates the nurse at the end of a care cycle) ────────────────
// Mandatory month-end feedback: one review per nurse per subscription. Feeds the
// caregiver's aggregate rating, which the matching engine uses.
model Review {
  id             String   @id @default(uuid())
  subscriptionId String
  caregiverId    String
  familyId       String
  rating         Int // 1..5 stars
  comment        String?
  createdAt      DateTime @default(now())

  subscription Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  caregiver    CaregiverProfile @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  family       FamilyProfile    @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, caregiverId])
  @@map("reviews")
}

// ─── Assignment (a nurse on a case, as primary or backup) ─────────────────────

model Assignment {
  id             String           @id @default(uuid())
  subscriptionId String
  caregiverId    String
  role           AssignmentRole
  status         AssignmentStatus @default(OFFERED)
  payoutGhs      Decimal?         @db.Decimal(10, 2)
  offeredAt      DateTime         @default(now())
  expiresAt      DateTime? // active-offer acceptance deadline (5-min escalation)
  respondedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  subscription Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  caregiver    CaregiverProfile @relation(fields: [caregiverId], references: [id])
  visits       Visit[]

  @@unique([subscriptionId, role])
  @@map("assignments")
}

// ─── Visit (a delivery; first one is the initial assessment) ──────────────────

model Visit {
  id             String      @id @default(uuid())
  subscriptionId String
  caregiverId    String
  assignmentId   String?
  kind           VisitKind   @default(CARE_VISIT)
  status         VisitStatus @default(SCHEDULED)
  scheduledFor   DateTime
  durationHrs    Float
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  subscription Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  caregiver    CaregiverProfile @relation(fields: [caregiverId], references: [id])
  assignment   Assignment?      @relation(fields: [assignmentId], references: [id])
  log          VisitLog?

  @@map("visits")
}

// ─── Visit log (daily care report; reviewed by the coordinator) ───────────────

model VisitLog {
  id                  String       @id @default(uuid())
  visitId             String       @unique
  summary             String
  observations        String?
  bloodPressure       String?
  bloodGlucose        String?
  heartRate           String?
  temperature         String?
  medicationsGiven    String[]
  quickLog            String[]
  mood                PatientMood?
  followUpRecommended Boolean      @default(false)
  escalationNeeded    Boolean      @default(false)
  changesRequested    Boolean      @default(false) // coordinator asked the nurse to revise
  reviewNotes         String[] // coordinator's change-request notes, oldest first (a thread)
  submittedAt         DateTime     @default(now())
  reviewedById        String? // coordinator who reviewed
  reviewedAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  visit      Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("LogReviewer", fields: [reviewedById], references: [id])

  @@map("visit_logs")
}

// ─── Payments (monthly subscription billing via Paystack) ─────────────────────

model Payment {
  id                 String        @id @default(uuid())
  subscriptionId     String
  familyId           String
  amount             Decimal       @db.Decimal(10, 2)
  currency           String        @default("GHS")
  status             PaymentStatus @default(PENDING)
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  paystackReference  String?       @unique
  paystackAccessCode String?
  paystackAuthUrl    String?
  paidAt             DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  subscription   Subscription    @relation(fields: [subscriptionId], references: [id])
  family         FamilyProfile   @relation(fields: [familyId], references: [id])
  payoutRequests PayoutRequest[]

  @@map("payments")
}

// A nurse's request to be paid for one completed subscription month (tied to
// the family's monthly Payment). Requestable only once that billing cycle has
// ended and the family has paid. An admin marks it PAID after disbursing.
model PayoutRequest {
  id          String       @id @default(uuid())
  caregiverId String
  paymentId   String // the subscription monthly payment this covers
  amountGhs   Decimal      @db.Decimal(10, 2)
  status      PayoutStatus @default(PENDING)
  requestedAt DateTime     @default(now())
  paidAt      DateTime?

  caregiver CaregiverProfile @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  payment   Payment          @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([caregiverId, paymentId]) // one payout per nurse per month
  @@index([caregiverId])
  @@map("payout_requests")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id     String           @id @default(uuid())
  userId String
  type   NotificationType
  title  String
  body   String
  isRead Boolean          @default(false)
  sentAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
