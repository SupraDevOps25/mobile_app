generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  FAMILY
  CAREGIVER // the nurse
  CARE_COORDINATOR
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

// Whether a family is booking care for themselves or for a loved one.
enum BookingFor {
  SELF
  LOVED_ONE
}

enum VerificationStatus {
  UNVERIFIED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

// Clinical competencies used for nurse matching. Mirrors the mobile
// CompetencyId catalog (constants/competencies.ts).
enum Competency {
  PERSONAL_CARE
  HYGIENE
  FEEDING
  MOBILITY
  MEDICATION
  VITALS
  WOUND_CARE
  CATHETER_CARE
  CHRONIC_DISEASE
  HYPERTENSION
  DIABETES
  STROKE_REHAB
  DEMENTIA
  GERIATRIC
  REHAB
  PALLIATIVE
}

enum PackageType {
  WELLNESS
  DAILY_ASSIST
  EXTENDED_ASSIST
  LIVE_IN
}

// Care journey states. AWAITING_ACTIVATION is the coordinator-controlled gate:
// after the initial assessment and the nurse starting, the Care Coordinator
// activates the care (it does not auto-start). See care-journey-workflow.
enum SubscriptionStatus {
  MATCHING // subscribed; system + coordinator assembling the care team
  TEAM_ASSIGNED // team set; initial home visit pending
  AWAITING_ACTIVATION // assessment done; awaiting coordinator activation
  ACTIVE // care delivery underway
  RENEWING // month-end review & renewal
  PAUSED
  CANCELLED
}

enum AssignmentRole {
  PRIMARY
  BACKUP_1
  BACKUP_2
}

enum AssignmentStatus {
  OFFERED
  ACCEPTED
  DECLINED
  ACTIVE
  REPLACED
}

enum VisitKind {
  INITIAL_ASSESSMENT // joint coordinator + nurse home visit
  CARE_VISIT
}

enum VisitStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  MISSED
}

enum PatientMood {
  POOR
  LOW
  GOOD
  GREAT
  EXCELLENT
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  ABANDONED
}

enum NotificationType {
  SUBSCRIPTION_CREATED
  TEAM_ASSIGNED
  ASSIGNMENT_OFFER
  ASSIGNMENT_ACCEPTED
  ASSIGNMENT_DECLINED
  CARE_ACTIVATED
  VISIT_REMINDER
  DAILY_LOG_SUBMITTED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  GENERAL
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  phone         String   @unique
  password      String
  firstName     String
  lastName      String
  role          Role
  emailVerified Boolean  @default(false)
  // Outbound notification channels (the in-app inbox is always on).
  notifyPush    Boolean  @default(true)
  notifySms     Boolean  @default(true)
  // Expo push token for this user's current device (any role).
  fcmToken      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  caregiverProfile   CaregiverProfile?
  familyProfile      FamilyProfile?
  notifications      Notification[]
  emailVerifications EmailVerification[]

  // Coordinator-side relations (role = CARE_COORDINATOR)
  coordinatedSubscriptions Subscription[] @relation("CoordinatorSubscriptions")
  reviewedLogs             VisitLog[]     @relation("LogReviewer")

  @@map("users")
}

model EmailVerification {
  id        String   @id @default(uuid())
  token     String   @unique @default(uuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// ─── Nurse (Caregiver) Profile ────────────────────────────────────────────────

model CaregiverProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  qualification      String?
  bio                String?
  yearsExperience    Int                @default(0)
  competencies       Competency[]
  serviceAreas       String[]
  licenseVerified    Boolean            @default(false)
  isAvailable        Boolean            @default(true) // nurse-controlled (availability screen)
  // Weekly working pattern (schedule screen). workingDays uses JS getDay():
  // 0=Sun … 6=Sat. Hours are "HH:MM" 24h strings.
  workingDays        Int[]              @default([1, 2, 3, 4, 5])
  workStart          String             @default("08:00")
  workEnd            String             @default("17:00")
  maxVisitsPerDay    Int                @default(3)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  rating             Decimal            @default(0) @db.Decimal(3, 2)
  reliabilityScore   Int                @default(0) // 0–100
  totalReviews       Int                @default(0)
  lat                Float?
  lng                Float?
  fcmToken           String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments Assignment[]
  visits      Visit[]

  @@map("caregiver_profiles")
}

// ─── Family Profile ───────────────────────────────────────────────────────────

model FamilyProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  address   String?
  lat       Float?
  lng       Float?
  fcmToken  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  careRecipients CareRecipient[]
  subscriptions  Subscription[]
  payments       Payment[]
  savedAddresses SavedAddress[]
  paymentMethods PaymentMethod[]

  @@map("family_profiles")
}

// A reusable Paystack authorization captured after a successful payment. We
// never store raw card details — only Paystack's token plus safe metadata.
// The authorizationCode is server-only and is never returned to the client.
model PaymentMethod {
  id                String   @id @default(uuid())
  familyId          String
  authorizationCode String   @unique
  channel           String // "card" | "mobile_money" | "bank"
  brand             String? // visa / mastercard / MTN, etc.
  last4             String?
  bank              String?
  expMonth          String?
  expYear           String?
  reusable          Boolean  @default(true)
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  family FamilyProfile @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("payment_methods")
}

model SavedAddress {
  id        String   @id @default(uuid())
  familyId  String
  label     String // "Home", "Work", "Other", or a custom label
  address   String // full address line
  area      String? // neighbourhood / area
  city      String?
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family FamilyProfile @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("saved_addresses")
}

// ─── Care Recipient (the client receiving care) ───────────────────────────────

model CareRecipient {
  id                String     @id @default(uuid())
  familyId          String
  bookingFor        BookingFor @default(LOVED_ONE) // self vs. loved one
  name              String
  age               Int
  gender            Gender
  relationToAccount String // "Self" when bookingFor = SELF; else e.g. "Father"
  area              String
  city              String
  address           String
  conditions        String[]
  basicCareNeeds    String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  family        FamilyProfile  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@map("care_recipients")
}

// ─── Package catalog ──────────────────────────────────────────────────────────

model Package {
  id         String      @id @default(uuid())
  type       PackageType @unique
  name       String
  tagline    String
  priceGhs   Decimal     @db.Decimal(10, 2)
  inclusions String[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("packages")
}

// ─── Subscription (the "case" container) ──────────────────────────────────────

model Subscription {
  id              String             @id @default(uuid())
  familyId        String
  careRecipientId String
  packageType     PackageType
  priceGhs        Decimal            @db.Decimal(10, 2) // snapshot at subscribe time
  status          SubscriptionStatus @default(MATCHING)
  coordinatorId   String? // User with role CARE_COORDINATOR
  careStartAt     DateTime? // day/time care begins, captured at assessment
  activatedAt     DateTime? // when the coordinator activated care
  startedAt       DateTime           @default(now())
  renewsAt        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  family        FamilyProfile @relation(fields: [familyId], references: [id])
  careRecipient CareRecipient @relation(fields: [careRecipientId], references: [id])
  coordinator   User?         @relation("CoordinatorSubscriptions", fields: [coordinatorId], references: [id])
  assignments   Assignment[]
  visits        Visit[]
  payments      Payment[]

  @@map("subscriptions")
}

// ─── Assignment (a nurse on a case, as primary or backup) ─────────────────────

model Assignment {
  id             String           @id @default(uuid())
  subscriptionId String
  caregiverId    String
  role           AssignmentRole
  status         AssignmentStatus @default(OFFERED)
  payoutGhs      Decimal?         @db.Decimal(10, 2)
  offeredAt      DateTime         @default(now())
  expiresAt      DateTime? // active-offer acceptance deadline (5-min escalation)
  respondedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  subscription Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  caregiver    CaregiverProfile @relation(fields: [caregiverId], references: [id])
  visits       Visit[]

  @@unique([subscriptionId, role])
  @@map("assignments")
}

// ─── Visit (a delivery; first one is the initial assessment) ──────────────────

model Visit {
  id             String      @id @default(uuid())
  subscriptionId String
  caregiverId    String
  assignmentId   String?
  kind           VisitKind   @default(CARE_VISIT)
  status         VisitStatus @default(SCHEDULED)
  scheduledFor   DateTime
  durationHrs    Float
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  subscription Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  caregiver    CaregiverProfile @relation(fields: [caregiverId], references: [id])
  assignment   Assignment?      @relation(fields: [assignmentId], references: [id])
  log          VisitLog?

  @@map("visits")
}

// ─── Visit log (daily care report; reviewed by the coordinator) ───────────────

model VisitLog {
  id                  String       @id @default(uuid())
  visitId             String       @unique
  summary             String
  observations        String?
  bloodPressure       String?
  bloodGlucose        String?
  heartRate           String?
  temperature         String?
  medicationsGiven    String[]
  quickLog            String[]
  mood                PatientMood?
  followUpRecommended Boolean      @default(false)
  escalationNeeded    Boolean      @default(false)
  submittedAt         DateTime     @default(now())
  reviewedById        String? // coordinator who reviewed
  reviewedAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  visit      Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("LogReviewer", fields: [reviewedById], references: [id])

  @@map("visit_logs")
}

// ─── Payments (monthly subscription billing via Paystack) ─────────────────────

model Payment {
  id                 String        @id @default(uuid())
  subscriptionId     String
  familyId           String
  amount             Decimal       @db.Decimal(10, 2)
  currency           String        @default("GHS")
  status             PaymentStatus @default(PENDING)
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  paystackReference  String?       @unique
  paystackAccessCode String?
  paystackAuthUrl    String?
  paidAt             DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  subscription Subscription  @relation(fields: [subscriptionId], references: [id])
  family       FamilyProfile @relation(fields: [familyId], references: [id])

  @@map("payments")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id     String           @id @default(uuid())
  userId String
  type   NotificationType
  title  String
  body   String
  isRead Boolean          @default(false)
  sentAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
